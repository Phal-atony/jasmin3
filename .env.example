# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Admin auth
ADMIN_JWT_SECRET="put-a-long-random-secret-at-least-32-chars-here"
ADMIN_2FA_CODE="246810"
ADMIN_2FA_TTL_SECONDS="300"

# Public URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# KHPay real payment config
KHPAY_BASE_URL="https://khpay.site/api/v1"
KHPAY_API_KEY=""
KHPAY_WEBHOOK_SECRET=""

# Local testing only. Never set true in production.
PAYMENT_SIMULATION_MODE="false"

# Optional local-dev fallback polling from public order GET.
# Never needed in production because production must be webhook/admin/internal only.
ALLOW_PUBLIC_PAYMENT_SYNC="false"

# CamRapidSecure old working top-up API
CAMRAPID_BASE_URL="https://partner.camrapidsecure.com/api"
CAMRAPID_API_KEY=""
